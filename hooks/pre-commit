#!/usr/bin/env bash
# 목적: 커밋 전 문서 게이트 2종.
#   (1) scripts/check_doc_form.py --staged — 스테이징된 .md가 문서 폼
#       (docs/docs-format/<유형>.md) 줄 예산을 지키는지.
#   (2) scripts/gen_readmes.py --check — 자동생성 인덱스(BLUF-INDEX) drift 0.
#       블록은 "수기 편집 금지"라 선언만 돼 있었고 강제가 없었다 — 사람·AI가
#       블록 안에 써도 커밋됐고, ship_check(출하)에서야 잡혀 그 사이 오염
#       커밋이 쌓였다(ADR 0014가 "pre-commit 배선은 후속"이라 예고한 그 후속).
#   둘 중 하나라도 비영 종료면 커밋을 막는다(git pre-commit 규약 — 0=통과).
#
# fail-open: 검사기 파일이 없으면 그 검사를 건너뛴다 — 파일 하나가 사라졌다고
#   저장소의 모든 커밋이 막히면 게이트가 자기 자신을 잠근다(ADR 0029 조건 1).
#
# 설치: 이 파일은 hooks/에 버전관리되고, scripts/install_hooks.py가
#   .git/hooks/로 복사·chmod +x 한다(.git/hooks는 버전관리 안 됨).
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [ -f "scripts/check_doc_form.py" ]; then
    python3 scripts/check_doc_form.py --staged
fi

if [ -f "scripts/gen_readmes.py" ]; then
    # 종료코드로 경우를 가른다. 2(블록 안 손글씨)는 gen_readmes가 이미 처방까지
    # 출력하므로 여기서 또 말하지 않는다 — 같은 규범을 두 곳에 두면 갈라진다.
    python3 scripts/gen_readmes.py --check || rc=$?
    if [ "${rc:-0}" -eq 1 ]; then
        cat >&2 <<'MSG'

[pre-commit] 위 README의 자동생성 인덱스가 원본과 어긋난다.
  → python3 scripts/gen_readmes.py 를 돌리고 바뀐 README도 같이 커밋하라.

MSG
        exit 1
    elif [ "${rc:-0}" -ne 0 ]; then
        exit "$rc"
    fi
fi
