#!/usr/bin/env bash
# 목적: 커밋 전 문서 게이트 2종 — 설치된 ai-harness CLI로 실행한다.
#   (1) ai-harness check-doc --staged — 스테이징된 .md가 문서 폼
#       (docs_format/<유형>.md) 줄 예산을 지키는지.
#   (2) ai-harness gen-readmes --check — 자동생성 인덱스(BLUF-INDEX)가 원본과
#       어긋나지 않는지(수기 편집·미갱신 0). 어긋나면 커밋을 막는다.
#   둘 중 하나라도 비영 종료면 커밋을 막는다(git pre-commit 규약 — 0=통과).
#
# fail-open: ai-harness 가 PATH에 없으면(미설치) 게이트를 건너뛴다 — CLI 하나가
#   없다고 저장소의 모든 커밋이 막히면 게이트가 자기 자신을 잠근다.
#
# 설치: ai-harness 는 `uv tool install`(또는 pip)로 머신에 한 번 설치한다. 이
#   훅 파일은 hooks/에 버전관리되고, `ai-harness install-hooks` 가 .git/hooks/로
#   복사·chmod +x 한다(.git/hooks는 버전관리 안 됨).
set -euo pipefail

if ! command -v ai-harness >/dev/null 2>&1; then
    exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

ai-harness check-doc --staged

# 종료코드로 경우를 가른다. 2(블록 안 손글씨)는 gen-readmes가 이미 처방까지
# 출력하므로 여기서 또 말하지 않는다 — 같은 규범을 두 곳에 두면 갈라진다.
ai-harness gen-readmes --check || rc=$?
if [ "${rc:-0}" -eq 1 ]; then
    cat >&2 <<'MSG'

[pre-commit] 위 README의 자동생성 인덱스가 원본과 어긋난다.
  → ai-harness gen-readmes 를 돌리고 바뀐 README도 같이 커밋하라.

MSG
    exit 1
elif [ "${rc:-0}" -ne 0 ]; then
    exit "$rc"
fi
